# Copier ce fichier en .env et adapter les valeurs.
# Le fichier .env réel ne doit JAMAIS être commité dans Git (voir .gitignore).

# Nom de l'application affiché dans le badge
APP_NAME=Todo Jenkins Lab

# Environnement courant : development | staging | production
APP_ENV=development

# Port d'écoute du serveur Express
PORT=3000

# Exemple de "secret" fictif pour illustrer le principe
# (ne jamais mettre un vrai secret ici en clair dans un vrai projet !)
API_SECRET=change-me
